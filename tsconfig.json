{
    "compilerOptions": {
      "outDir": "./dist/",
      "module": "esnext",
      "target": "es6",
      "moduleResolution": "bundler",
      "esModuleInterop": true,
      "resolveJsonModule": true,
      "declaration": false,
      "noImplicitAny": true,
      "removeComments": true,
      "skipLibCheck": true,
      "types": ["node"],
      "rootDir": "./src",
      "paths": {
        "@types": ["./src/types"],
        "@constants": ["./src/constants"],
        "@utilities": ["./src/utilities"]  
      }
    },
    "include": ["src/**/*.ts", "package.json"],
    "exclude": ["node_modules"]
  }